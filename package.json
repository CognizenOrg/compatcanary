{
  "name": "compatcanary",
  "version": "0.2.2",
  "description": "Evidence-first compatibility scanner for OpenAI-style APIs",
  "type": "module",
  "bin": {
    "compatcanary": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "check": "node --check src/cli.js && node --check src/action.js && node --check src/evidence.js && node --check scripts/build-evidence.js",
    "evidence:build": "node scripts/build-evidence.js",
    "evidence:check": "node scripts/build-evidence.js --check",
    "test": "node --test test/*.test.js",
    "test:integration": "node --test test/integration.test.js",
    "mock": "node test/fixtures/mock-server.js",
    "scan:help": "node src/cli.js --help"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openai-compatible",
    "api-testing",
    "llm",
    "conformance",
    "github-action"
  ],
  "license": "MIT",
  "files": [
    "src",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "docs/REPORT-SCHEMA.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CognizenOrg/compatcanary.git"
  },
  "bugs": {
    "url": "https://github.com/CognizenOrg/compatcanary/issues"
  },
  "homepage": "https://github.com/CognizenOrg/compatcanary#readme"
}
